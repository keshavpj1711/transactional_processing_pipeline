# Copy to .env to override defaults. The stack runs without this file using the
# defaults baked into docker-compose.yml; the only reason to set anything here is
# to enable real LLM calls (otherwise the deterministic stub is used).

# --- Storage / messaging (defaults match docker-compose) ---
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/transactions
REDIS_URL=redis://redis:6379/0

# --- LLM (OpenRouter, OpenAI-compatible) ---
# Leave OPENROUTER_API_KEY empty to run the deterministic stub classifier with no
# external calls. Set it to use a real model.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Force the stub even if a key is present (useful for reproducible runs/tests).
USE_STUB_LLM=false

# --- Pipeline tuning ---
LLM_CLASSIFY_BATCH_SIZE=20
LLM_MAX_RETRIES=3
